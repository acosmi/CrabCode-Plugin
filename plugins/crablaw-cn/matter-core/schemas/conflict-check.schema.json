{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crablaw.local/schemas/matter-core/conflict-check.schema.json",
  "title": "CrabLaw-CN Conflict Screening",
  "type": "object",
  "required": ["matterId", "status", "screenedAt", "queries", "hits"],
  "properties": {
    "matterId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
    "status": { "enum": ["pending", "no-hit", "hit-review-required", "cleared-by-lawyer", "declined"] },
    "screenedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "screenedBy": { "type": "string", "minLength": 1 },
    "queries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "summary", "risk"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "matchedMatterId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
          "summary": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["low", "medium", "high", "unknown"] },
          "recommendedAction": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "lawyerConfirmation": {
      "type": "object",
      "properties": {
        "status": { "enum": ["not-reviewed", "confirmed-clear", "waiver-needed", "declined"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
        "notes": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "enum": ["confirmed-clear", "waiver-needed", "declined"] } },
            "required": ["status"]
          },
          "then": { "required": ["reviewer", "reviewedAt"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "no-hit" } },
        "required": ["status"]
      },
      "then": {
        "properties": { "hits": { "maxItems": 0 } }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "hit-review-required" } },
        "required": ["status"]
      },
      "then": {
        "properties": { "hits": { "minItems": 1 } }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "cleared-by-lawyer" } },
        "required": ["status"]
      },
      "then": {
        "required": ["lawyerConfirmation"],
        "properties": {
          "lawyerConfirmation": {
            "required": ["status", "reviewer", "reviewedAt"],
            "properties": { "status": { "const": "confirmed-clear" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "declined" } },
        "required": ["status"]
      },
      "then": {
        "required": ["lawyerConfirmation"],
        "properties": {
          "lawyerConfirmation": {
            "required": ["status", "reviewer", "reviewedAt"],
            "properties": { "status": { "const": "declined" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "pending" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "lawyerConfirmation": {
            "properties": { "status": { "const": "not-reviewed" } }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
