{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crablaw.local/schemas/matter-core/matter.schema.json",
  "title": "CrabLaw-CN Matter",
  "type": "object",
  "required": ["matterId", "clientId", "title", "status", "engagementScope", "openedAt"],
  "properties": {
    "matterId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
    "clientId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,80}$" },
    "title": { "type": "string", "minLength": 1 },
    "matterType": {
      "enum": [
        "contract",
        "data-compliance",
        "labor-employment",
        "corporate",
        "ip",
        "litigation",
        "ai-governance",
        "other"
      ]
    },
    "status": { "enum": ["active", "pending-conflict-review", "paused", "closed", "archived"] },
    "engagementScope": { "type": "string", "minLength": 1 },
    "responsibleLawyer": { "type": "string", "minLength": 1 },
    "reviewOwner": { "type": "string", "minLength": 1 },
    "openedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "closedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "retentionPolicy": { "type": "string", "minLength": 1 },
    "sourcePolicy": { "type": "string", "minLength": 1 },
    "notes": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "enum": ["closed", "archived"] } },
        "required": ["status"]
      },
      "then": { "required": ["closedAt"] }
    }
  ],
  "additionalProperties": false
}
