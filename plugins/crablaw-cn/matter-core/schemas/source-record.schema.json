{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crablaw.local/schemas/matter-core/source-record.schema.json",
  "title": "CrabLaw-CN Source Record",
  "type": "object",
  "required": ["sourceId", "matterId", "sourceType", "title", "retrievedAt", "status"],
  "properties": {
    "sourceId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,120}$" },
    "matterId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
    "sourceType": { "enum": ["official-law", "official-guidance", "case", "user-provided", "internal-knowledge", "model-knowledge-verify", "web-verify"] },
    "title": { "type": "string", "minLength": 1 },
    "authority": { "type": "string", "minLength": 1 },
    "urlOrRecordId": { "type": "string", "minLength": 1 },
    "retrievedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "effectiveStatus": { "type": "string", "minLength": 1 },
    "pinpoint": { "type": "string", "minLength": 1 },
    "excerpt": { "type": "string", "minLength": 1 },
    "status": { "enum": ["unreviewed", "lawyer-reviewed", "source-needs-check", "superseded", "unknown"] },
    "reviewer": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "lawyer-reviewed" } },
        "required": ["status"]
      },
      "then": { "required": ["reviewer"] }
    },
    {
      "if": {
        "properties": { "sourceType": { "enum": ["official-law", "official-guidance", "case", "web-verify"] } },
        "required": ["sourceType"]
      },
      "then": { "required": ["authority", "urlOrRecordId", "effectiveStatus"] }
    },
    {
      "if": {
        "properties": { "status": { "const": "superseded" } },
        "required": ["status"]
      },
      "then": { "required": ["effectiveStatus"] }
    },
    {
      "if": {
        "properties": { "status": { "const": "source-needs-check" } },
        "required": ["status"]
      },
      "then": { "required": ["effectiveStatus"] }
    }
  ],
  "additionalProperties": false
}
