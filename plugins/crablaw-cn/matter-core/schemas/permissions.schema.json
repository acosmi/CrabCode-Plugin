{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crablaw.local/schemas/matter-core/permissions.schema.json",
  "title": "CrabLaw-CN Matter Permissions",
  "type": "object",
  "required": ["matterId", "accessMode", "allowedUsers", "crossMatterAccess"],
  "properties": {
    "matterId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
    "accessMode": { "enum": ["standard", "heightened", "clean-team"] },
    "allowedUsers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "allowedTeams": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "restrictedPaths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "crossMatterAccess": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "authorizedBy": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": { "required": ["authorizedBy", "reason", "expiresAt"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
