{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crabcode.local/media/delivery-manifest.schema.json",
  "title": "Verified HTML-primary delivery manifest",
  "type": "object",
  "required": ["deliveryId", "contentId", "revisionId", "contentHash", "articleDocHash", "primaryArtifact", "backupArtifact", "channelArtifacts", "assets", "rendererVersion", "templateId", "templateVersion", "stylePolicyVersion", "sanitizationPolicyVersion", "dependencyLockHash", "renderInputsHash", "parityStatus", "securityStatus", "semanticStatus", "accessibilityStatus", "visualReviewStatus", "checks", "renderManifestHash", "generatedAt", "generatedBy", "artifactRoot"],
  "properties": {
    "deliveryId": { "type": "string", "format": "uuid" },
    "contentId": { "type": "string", "format": "uuid" },
    "revisionId": { "type": "string", "format": "uuid" },
    "contentHash": { "$ref": "#/$defs/sha256" },
    "articleDocHash": { "$ref": "#/$defs/sha256" },
    "primaryArtifact": { "allOf": [{ "$ref": "delivery-artifact.schema.json" }, { "properties": { "role": { "const": "primary" }, "format": { "const": "html" } } }] },
    "backupArtifact": { "allOf": [{ "$ref": "delivery-artifact.schema.json" }, { "properties": { "role": { "const": "backup" }, "format": { "const": "markdown" } } }] },
    "channelArtifacts": { "type": "array", "items": { "$ref": "delivery-artifact.schema.json" } },
    "assets": { "type": "array", "maxItems": 100, "items": { "type": "object", "required": ["assetId", "relativePath", "sha256", "byteSize", "mediaType"], "properties": { "assetId": { "type": "string", "format": "uuid" }, "relativePath": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*:)[A-Za-z0-9._/-]+$" }, "sha256": { "$ref": "#/$defs/sha256" }, "byteSize": { "type": "integer", "minimum": 1 }, "mediaType": { "type": "string", "minLength": 1 } }, "additionalProperties": false } },
    "rendererVersion": { "type": "string" },
    "templateId": { "type": "string" },
    "templateVersion": { "type": "string" },
    "stylePolicyVersion": { "type": "string" },
    "sanitizationPolicyVersion": { "type": "string" },
    "dependencyLockHash": { "$ref": "#/$defs/sha256" },
    "renderInputsHash": { "$ref": "#/$defs/sha256" },
    "parityStatus": { "enum": ["passed", "failed"] },
    "securityStatus": { "enum": ["passed", "failed"] },
    "semanticStatus": { "enum": ["passed", "failed"] },
    "accessibilityStatus": { "enum": ["passed", "failed", "manual_required"] },
    "visualReviewStatus": { "enum": ["pending", "passed", "failed"] },
    "checks": { "type": "array", "items": { "type": "object", "required": ["id", "status", "detail"], "properties": { "id": { "type": "string", "minLength": 1 }, "status": { "enum": ["passed", "failed"] }, "detail": { "type": "string", "minLength": 1 } }, "additionalProperties": false } },
    "visualReview": { "type": "object", "required": ["reviewedBy", "reviewedAt", "viewports", "printChecked", "notes"], "properties": { "reviewedBy": { "type": "string", "minLength": 1 }, "reviewedAt": { "type": "string", "format": "date-time" }, "viewports": { "type": "array", "minItems": 3, "items": { "type": "object", "required": ["width", "height", "noHorizontalOverflow", "whiteBackground", "readable"], "properties": { "width": { "type": "integer", "minimum": 1 }, "height": { "type": "integer", "minimum": 1 }, "noHorizontalOverflow": { "type": "boolean" }, "whiteBackground": { "type": "boolean" }, "readable": { "type": "boolean" } }, "additionalProperties": false } }, "printChecked": { "type": "boolean" }, "notes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } } }, "additionalProperties": false },
    "verifiedBy": { "type": "string" },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "renderManifestHash": { "$ref": "#/$defs/sha256" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "generatedBy": { "type": "string" },
    "artifactRoot": { "type": "string", "minLength": 1 }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
  "additionalProperties": false
}
