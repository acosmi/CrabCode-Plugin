{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crabcode.local/media/originality-scan.schema.json",
  "title": "Originality risk scan",
  "type": "object",
  "required": ["scanId", "contentId", "sourceRevisionId", "subjectHash", "referenceHashes", "quotations", "algorithmVersion", "policyVersion", "parameters", "exactMatches", "longestNormalizedMatch", "draftCoverage", "referenceCoverage", "ngramMatches", "paragraphAlignments", "outlineSimilarity", "semanticFlags", "decision", "reviewRequired", "createdAt", "createdBy", "scanHash"],
  "properties": {
    "scanId": { "type": "string", "format": "uuid" },
    "contentId": { "type": "string", "format": "uuid" },
    "sourceRevisionId": { "type": "string", "format": "uuid" },
    "subjectHash": { "$ref": "#/$defs/sha256" },
    "referenceHashes": { "type": "array", "maxItems": 100, "items": { "type": "object", "required": ["referenceId", "contentHash", "role"], "properties": { "referenceId": { "type": "string", "format": "uuid" }, "contentHash": { "$ref": "#/$defs/sha256" }, "role": { "enum": ["user_owned_draft", "authorized_sample", "third_party_reference", "factual_source"] } }, "additionalProperties": false } },
    "quotations": { "type": "array", "maxItems": 20, "items": { "type": "object", "required": ["referenceId", "text", "attribution", "locator"], "properties": { "referenceId": { "type": "string", "format": "uuid" }, "text": { "type": "string", "minLength": 1, "maxLength": 200 }, "attribution": { "type": "string", "minLength": 1, "maxLength": 300 }, "locator": { "type": "string", "minLength": 1, "maxLength": 300 } }, "additionalProperties": false } },
    "algorithmVersion": { "type": "string" },
    "policyVersion": { "type": "string" },
    "parameters": { "type": "object", "required": ["ngramSizes", "paragraphThreshold"], "properties": { "ngramSizes": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "integer", "minimum": 1 } }, "paragraphThreshold": { "type": "number", "minimum": 0, "maximum": 1 }, "paragraphCandidateLimit": { "type": "integer", "minimum": 1 } }, "additionalProperties": false },
    "exactMatches": { "type": "array", "maxItems": 20, "items": { "type": "object", "required": ["referenceId", "text", "length"], "properties": { "referenceId": { "type": "string", "format": "uuid" }, "text": { "type": "string", "maxLength": 200 }, "length": { "type": "integer", "minimum": 0 } }, "additionalProperties": false } },
    "longestNormalizedMatch": { "type": "integer", "minimum": 0 },
    "draftCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "referenceCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "ngramMatches": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "paragraphAlignments": { "type": "array", "maxItems": 100, "items": { "type": "object", "required": ["referenceId", "draftIndex", "referenceIndex", "similarity"], "properties": { "referenceId": { "type": "string", "format": "uuid" }, "draftIndex": { "type": "integer", "minimum": 0 }, "referenceIndex": { "type": "integer", "minimum": 0 }, "similarity": { "type": "number", "minimum": 0, "maximum": 1 } }, "additionalProperties": false } },
    "outlineSimilarity": { "type": "number", "minimum": 0, "maximum": 1 },
    "semanticFlags": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 500 } },
    "decision": { "enum": ["blocked", "changes_required", "human_review_required", "low_risk"] },
    "reviewRequired": { "type": "boolean" },
    "humanReview": { "type": "object", "required": ["decision", "reviewedBy", "reviewedAt", "rationale", "structureIndependent", "argumentIndependent", "attributedQuotations"], "properties": { "decision": { "enum": ["pass", "changes_required"] }, "reviewedBy": { "type": "string", "minLength": 1 }, "reviewedAt": { "type": "string", "format": "date-time" }, "rationale": { "type": "string", "minLength": 20, "maxLength": 3000 }, "structureIndependent": { "type": "boolean" }, "argumentIndependent": { "type": "boolean" }, "attributedQuotations": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 500 } } }, "additionalProperties": false },
    "createdAt": { "type": "string", "format": "date-time" },
    "createdBy": { "type": "string" },
    "scanHash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
  "additionalProperties": false
}
