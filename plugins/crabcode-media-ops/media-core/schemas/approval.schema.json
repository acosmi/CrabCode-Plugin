{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crabcode.local/media/approval.schema.json",
  "title": "Authenticated artifact-bound publish approval v3",
  "type": "object",
  "required": ["schemaVersion", "transitionVersion", "approvalId", "contentId", "revisionId", "contentHash", "articleDocHash", "deliveryId", "renderManifestHash", "primaryArtifactHash", "backupArtifactHash", "channelArtifactHashes", "rendererVersion", "templateVersion", "stylePolicyVersion", "sanitizationPolicyVersion", "platformRuleVersion", "approvalBindingHash", "platform", "state", "summary", "checklist", "requestedBy", "requestedIdentity"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "transitionVersion": { "type": "integer", "minimum": 1 },
    "approvalId": { "type": "string", "format": "uuid" },
    "contentId": { "type": "string", "format": "uuid" },
    "revisionId": { "type": "string", "format": "uuid" },
    "contentHash": { "$ref": "#/$defs/sha256" },
    "articleDocHash": { "$ref": "#/$defs/sha256" },
    "deliveryId": { "type": "string", "format": "uuid" },
    "renderManifestHash": { "$ref": "#/$defs/sha256" },
    "primaryArtifactHash": { "$ref": "#/$defs/sha256" },
    "backupArtifactHash": { "$ref": "#/$defs/sha256" },
    "channelArtifactHashes": { "type": "array", "items": { "$ref": "#/$defs/sha256" } },
    "rendererVersion": { "type": "string", "minLength": 1 },
    "templateVersion": { "type": "string", "minLength": 1 },
    "stylePolicyVersion": { "type": "string", "minLength": 1 },
    "sanitizationPolicyVersion": { "type": "string", "minLength": 1 },
    "platformRuleVersion": { "type": "string", "minLength": 1 },
    "approvalBindingHash": { "$ref": "#/$defs/sha256" },
    "platform": { "enum": ["wechat", "xhs", "toutiao"] },
    "state": { "enum": ["pending", "approved", "rejected", "revoked"] },
    "summary": { "type": "string", "minLength": 1 },
    "checklist": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "requestedBy": { "type": "string", "minLength": 1 },
    "requestedIdentity": { "$ref": "#/$defs/identity" },
    "decidedBy": { "type": "string", "minLength": 1 },
    "decidedIdentity": { "$ref": "#/$defs/identity" },
    "reason": { "type": "string", "minLength": 1 },
    "decidedAt": { "type": "string", "format": "date-time" },
    "packageId": { "type": "string", "format": "uuid" },
    "packagedBy": { "type": "string", "minLength": 1 },
    "packagedIdentity": { "$ref": "#/$defs/identity" },
    "packagedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "identity": { "type": "object", "required": ["principalId", "issuer", "assurance"], "properties": { "principalId": { "type": "string", "minLength": 1 }, "issuer": { "type": "string", "minLength": 1 }, "assurance": { "enum": ["mcp_oauth", "host_principal"] } }, "additionalProperties": false }
  },
  "allOf": [
    {
      "if": { "properties": { "state": { "const": "pending" } }, "required": ["state"] },
      "then": { "not": { "anyOf": [
        { "required": ["decidedBy"] }, { "required": ["decidedIdentity"] }, { "required": ["reason"] }, { "required": ["decidedAt"] },
        { "required": ["packageId"] }, { "required": ["packagedBy"] }, { "required": ["packagedIdentity"] }, { "required": ["packagedAt"] }
      ] } },
      "else": { "required": ["decidedBy", "decidedIdentity", "reason", "decidedAt"] }
    },
    {
      "if": { "anyOf": [
        { "required": ["packageId"] }, { "required": ["packagedBy"] }, { "required": ["packagedIdentity"] }, { "required": ["packagedAt"] }
      ] },
      "then": {
        "required": ["packageId", "packagedBy", "packagedIdentity", "packagedAt"],
        "properties": { "state": { "const": "approved" } }
      }
    }
  ],
  "additionalProperties": false
}
