{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crabcode.local/media/creator-style-form.schema.json",
  "title": "Creator style intake form",
  "type": "object",
  "required": ["brandId", "formId", "mode", "state", "data", "updatedBy"],
  "properties": {
    "brandId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
    "formId": { "type": "string", "format": "uuid" },
    "mode": { "enum": ["quick", "full", "incremental"] },
    "state": { "enum": ["draft", "submitted", "confirmed", "superseded"] },
    "data": {
      "type": "object",
      "required": ["displayName", "creatorTypes", "positioning", "audience", "expression", "structure", "language", "truthBoundaries", "samples", "platformDifferences", "consent"],
      "properties": {
        "creatorTypes": { "type": "array", "minItems": 1 },
        "truthBoundaries": { "type": "object" },
        "samples": { "type": "array" },
        "consent": { "type": "object" }
      },
      "additionalProperties": true
    },
    "updatedBy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
