{
  "name": "crabcode-setup",
  "version": "0.1.0",
  "description": "Analyze a repository and recommend CrabCode-native automations such as skills, hooks, agents, plugins, and MCP servers.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "crabcode-setup": "./dist/cli.js"
  },
  "scripts": {
    "analyze": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node --format esm --banner '#!/usr/bin/env node'",
    "lint:brand": "bun run scripts/lint-brand.ts",
    "lint:manifest": "bun run scripts/validate-manifest.ts",
    "lint:marketplace": "bun run scripts/validate-marketplace.ts",
    "lint:layout": "bun run scripts/validate-layout.ts",
    "lint:tool-scope": "bun run scripts/lint-tool-scope.ts",
    "lint:refs": "bun run scripts/validate-references.ts",
    "validate": "bun run scripts/validate-all.ts",
    "test": "bun test ./tests/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
